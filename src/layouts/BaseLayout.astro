---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const baseWithSlash = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const {
  title,
  description = "monta のブログ",
  ogType = "website",
  ogImage = new URL(`${baseWithSlash}og/default.png`, Astro.site).toString(),
  ogImageAlt = "monta's blog",
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props;

const siteTitle = "monta's blog";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const normalizedOgImage = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description || "monta のブログ"} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description || "monta のブログ"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:image" content={normalizedOgImage} />
    <meta property="og:image:secure_url" content={normalizedOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:domain" content={canonicalURL.hostname} />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description || "monta のブログ"} />
    <meta name="twitter:image" content={normalizedOgImage} />
    <meta name="twitter:image:src" content={normalizedOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="twitter:site" content="@monta3135" />
    <meta name="twitter:creator" content="@monta3135" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href={new URL("rss.xml", Astro.site)}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href={`${baseWithSlash}favicon.jpg`} />
  </head>
  <body>
    <Header />
    <main class="container" style="flex: 1; padding-block: 2rem;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
