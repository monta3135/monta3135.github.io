---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import BaseLayout from "./BaseLayout.astro";

interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  tocHeadings?: TocHeading[];
}

const { post, tocHeadings = [] } = Astro.props;
const { title, description, pubDate, updatedDate, categories } = post.data;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const hasToc = tocHeadings.length > 0;
const minTocDepth = hasToc
  ? Math.min(...tocHeadings.map((heading) => heading.depth))
  : 0;

// Generate the URL for the static OG image endpoint
const ogImageURL = new URL(
  `${baseUrl}og/${post.slug}.png`,
  Astro.site,
).toString();
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImageURL}
  ogImageAlt={title}
>
  <div class="post-layout">
    {
      hasToc && (
        <aside class="post-toc">
          <nav class="post-toc-inner" aria-label="目次" data-post-toc>
            <p class="toc-title">目次</p>
            <ol class="toc-list">
              {tocHeadings.map((heading) => (
                <li
                  class:list={[
                    "toc-item",
                    {
                      "toc-item--child": heading.depth > minTocDepth,
                      "toc-item--grandchild": heading.depth > minTocDepth + 1,
                    },
                  ]}
                >
                  <a href={`#${heading.slug}`} class="toc-link" data-toc-link data-toc-id={heading.slug}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )
    }

    <article class="post-article">
      <header class="post-header">
        <div class="post-meta">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <span class="updated-date">
                — <FormattedDate date={updatedDate} /> 更新
              </span>
            )
          }
        </div>

        <h1 class="post-title">{title}</h1>

        {
          categories.length > 0 && (
            <div class="post-categories">
              {categories.map((cat) => (
                <a href={`${baseUrl}categories/${cat}`} class="tag">{cat}</a>
              ))}
            </div>
          )
        }
      </header>

      <div class="prose post-body">
        <slot />
      </div>

      <footer class="post-footer">
        <a href={`${import.meta.env.BASE_URL}`}>← 一覧へ戻る</a>
      </footer>
    </article>
  </div>

  {
    hasToc && (
      <script is:inline>
        const tocRoot = document.querySelector("[data-post-toc]");
        if (tocRoot instanceof HTMLElement) {
          const links = Array.from(tocRoot.querySelectorAll("a[data-toc-link]"));
          const headingElements = links
            .map((link) => {
              const id = link.getAttribute("data-toc-id");
              return id ? document.getElementById(id) : null;
            })
            .filter((heading) => heading instanceof HTMLElement);

          if (links.length > 0 && headingElements.length > 0) {
            const activeOffset = 96;

            const setActiveLink = (id) => {
              for (const link of links) {
                if (link.getAttribute("data-toc-id") === id) {
                  link.setAttribute("aria-current", "location");
                } else {
                  link.removeAttribute("aria-current");
                }
              }
            };

            const syncActiveHeading = () => {
              let activeId = headingElements[0].id;
              for (const heading of headingElements) {
                if (heading.getBoundingClientRect().top <= activeOffset) {
                  activeId = heading.id;
                } else {
                  break;
                }
              }
              setActiveLink(activeId);
            };

            let ticking = false;
            const onScroll = () => {
              if (ticking) {
                return;
              }
              ticking = true;
              window.requestAnimationFrame(() => {
                syncActiveHeading();
                ticking = false;
              });
            };

            syncActiveHeading();
            document.addEventListener("scroll", onScroll, { passive: true });
            window.addEventListener("resize", syncActiveHeading);
          }
        }
      </script>
    )
  }
</BaseLayout>

<style>
  :global(main.container) {
    max-width: min(1400px, 100%);
  }

  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      "toc"
      "content";
    gap: 1.75rem;
  }

  .post-article {
    grid-area: content;
    min-width: 0;
    max-width: 760px;
    margin-inline: auto;
  }

  .post-toc {
    grid-area: toc;
    align-self: start;
  }

  .post-toc-inner {
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    background-color: color-mix(in srgb, var(--bg) 94%, var(--bg-secondary));
    box-shadow: 0 14px 30px -28px color-mix(in srgb, var(--text) 80%, transparent);
    padding: 0.9rem 1rem;
    --toc-tree-line: color-mix(in srgb, var(--accent) 42%, var(--border));
    --toc-tree-node: color-mix(in srgb, var(--accent) 62%, var(--text-muted));
  }

  .toc-title {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text);
    margin-bottom: 0.7rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding-left: 1rem;
    position: relative;
  }

  .toc-list::before {
    content: "";
    position: absolute;
    left: 0.2rem;
    top: 0.15rem;
    bottom: 0.15rem;
    width: 2px;
    background-color: var(--toc-tree-line);
  }

  .toc-item {
    position: relative;
    padding-left: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .toc-item::before {
    content: "";
    position: absolute;
    top: 0.85em;
    left: 0.2rem;
    width: 0.8rem;
    height: 2px;
    background-color: var(--toc-tree-line);
  }

  .toc-item::after {
    content: "";
    position: absolute;
    top: calc(0.85em - 0.18rem);
    left: calc(0.2rem - 0.16rem);
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background-color: var(--toc-tree-node);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--bg) 85%, transparent);
  }

  .toc-item--child {
    margin-left: 1.2rem;
  }

  .toc-item--grandchild {
    margin-left: 2rem;
  }

  .toc-link {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: 1.45;
    padding: 0.12rem 0.3rem 0.12rem 0.15rem;
    border-radius: 0.35rem;
    transition: color var(--transition);
    text-wrap: pretty;
  }

  .toc-link:hover {
    color: var(--text);
  }

  .toc-link[aria-current="location"] {
    color: var(--accent);
    font-weight: 700;
    background-color: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .updated-date {
    margin-left: 0.25rem;
  }

  .post-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    line-height: 1.25;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .post-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .post-body {
    margin-top: 2rem;
  }

  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    scroll-margin-top: calc(var(--header-height) + 1rem);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: var(--text-sm);
  }

  .post-footer a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .post-footer a:hover {
    color: var(--accent);
  }

  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: minmax(0, 760px) minmax(15rem, 18rem);
      grid-template-areas: "content toc";
      justify-content: center;
      gap: 2.25rem;
      align-items: start;
    }

    .post-toc {
      position: sticky;
      top: calc(var(--header-height) + 1rem);
    }

    .post-toc-inner {
      max-height: calc(100dvh - var(--header-height) - 2rem);
      overflow: auto;
    }
  }

  @media (min-width: 1360px) {
    .post-layout {
      grid-template-columns: 16rem minmax(0, 760px) 16rem;
      gap: 2rem;
    }

    .post-article {
      grid-column: 2;
      max-width: none;
    }

    .post-toc {
      grid-column: 3;
    }
  }
</style>
