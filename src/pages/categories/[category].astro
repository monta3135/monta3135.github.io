---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map((post) => post.data.categories).flat())];

  return categories.map((category) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.categories.includes(category)
    );
    return {
      params: { category },
      props: { posts: filteredPosts },
    };
  });
}

const { category } = Astro.params;
const { posts } = Astro.props;

// Sort posts by date (newest first)
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title={`Category: ${category}`}
  description={`Posts categorized under ${category}`}
>
  <div class="category-page">
    <header class="category-header">
      <h1 class="category-title">
        Category: <span class="text-accent">{category}</span>
      </h1>
      <p class="category-desc">
        {posts.length} {posts.length === 1 ? "post" : "posts"} found
      </p>
    </header>

    <section class="posts-section" aria-label="記事一覧">
      {
        sortedPosts.length === 0 ? (
          <p class="empty-state">記事がまだありません。</p>
        ) : (
          <ul class="post-list">
            {sortedPosts.map((post) => (
              <li>
                <PostCard post={post} />
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .category-page {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .category-header {
    padding-block: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .category-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }

  .text-accent {
    color: var(--accent);
  }

  .category-desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
  }

  .posts-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty-state {
    color: var(--text-muted);
    text-align: center;
    padding: 3rem 0;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
  }
</style>
